<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for WKWebView JIT compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for WebKit unsigned memory -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for loading Tauri plugins as dylibs -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!--
    Note: NO `com.apple.security.automation.apple-events` here.
    That entitlement covers AppleScript-style automation (NSAppleEvent /
    OSAScript), NOT the synthetic keyboard input we actually do via
    `enigo`'s `CGEventPost`. Synthetic input is gated by the runtime TCC
    "Accessibility" permission (granted in System Settings), which has
    nothing to do with code-signing entitlements. Including the apple-events
    key with Hardened Runtime can additionally trigger an unrelated TCC
    "Automation" prompt on macOS Tahoe and confuses the permission flow.
  -->
</dict>
</plist>
